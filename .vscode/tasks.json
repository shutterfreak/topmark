{
  // VS Code Tasks for quick linting & type checking from the Command Palette
  "version": "2.0.0",
  "options": {
    // Prefer virtualenv binaries when present
    "shell": {
      "executable": "/bin/bash",
      "args": ["-lc"]
    },
    "env": {
      "PATH": "${workspaceFolder}/.venv/bin:${env:PATH}"
    }
  },
  "tasks": [
    {
      "label": "Make: Verify",
      "type": "shell",
      "command": "make verify",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Make: Format Check",
      "type": "shell",
      "command": "make format-check",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "Make: Lint",
      "type": "shell",
      "command": "make lint",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "Make: Docs Hygiene",
      "type": "shell",
      "command": "make docs-hygiene",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "Make: Code Hygiene",
      "type": "shell",
      "command": "make code-hygiene",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "Nox: QA",
      "type": "shell",
      "command": "nox -s qa",
      "group": "test",
      "problemMatcher": []
    }
  ]
}
